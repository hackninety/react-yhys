# .env.example for yhys-calendar (Production)
# Rename this file to .env on your server

# ------------------------------
# Application Configuration
# ------------------------------
# Port to expose the application on the host (Default: 3000)
# If you want to run on port 80 directly, set this to 80
APP_PORT=3000

# ------------------------------
# Database Configuration
# ------------------------------
# Root password for MySQL (CHANGE THIS!)
DB_ROOT_PASSWORD=your_secure_root_password_here

# Database name
DB_NAME=yhys_calendar

# Creating a specific user (Optional, but recommended)
DB_USER=yhys_user
DB_PASSWORD=your_secure_user_password_here

# Port to expose MySQL on the host (Default: 3306)
# Set to a different port or 127.0.0.1:3306 to limit access
DB_PORT=3306
